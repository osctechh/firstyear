---
import osito from "../assets/osito.jpg";
import Palmera from "../assets/Palmera.webp";
import pelota from "../assets/pelota.webp";
import Navidad from "../assets/navidad.jpg";
import Princesa from "../assets/pincesa.webp";
---

<section
  class="min-h-screen relative flex items-center justify-center overflow-hidden -mt-20"
>
  <div class="w-full max-w-2xl mt-2 mx-72 px-2">
    <div class="relative">
      <div class="overflow-hidden rounded-2xl shadow-2xl">
        <div
          class="flex transition-transform duration-500 ease-in-out"
          id="carousel"
        >
          <div class="w-full shrink-0">
            <img
              src={osito.src}
              alt="Foto 1 del bebé"
              class="w-full h-80 sm:h-96 md:h-128 lg:h-144 object-cover"
            />
          </div>
          <div class="w-full shrink-0">
            <img
              src={Palmera.src}
              alt="Foto 2 del bebé"
              class="w-full h-80 sm:h-96 md:h-128 lg:h-144 object-cover"
            />
          </div>
          <div class="w-full shrink-0">
            <img
              src={pelota.src}
              alt="Foto 3 del bebé"
              class="w-full h-80 sm:h-96 md:h-128 lg:h-144 object-cover"
            />
          </div>
          <div class="w-full shrink-0">
            <img
              src={Navidad.src}
              alt="Foto 3 del bebé"
              class="w-full h-80 sm:h-96 md:h-128 lg:h-144 object-cover"
            />
          </div>
          <div class="w-full shrink-0">
            <img
              src={Princesa.src}
              alt="Foto 3 del bebé"
              class="w-full h-80 sm:h-96 md:h-128 lg:h-144 object-cover"
            />
          </div>
        </div>
      </div>

      <button
        id="prevBtn"
        class="absolute left-2 sm:left-4 top-1/2 -translate-y-1/2 bg-white/80 hover:bg-white text-gray-800 rounded-full p-2 sm:p-3 shadow-lg transition-all hover:scale-110"
        aria-label="Anterior"
      >
        <svg
          class="w-4 h-4 sm:w-6 sm:h-6"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M15 19l-7-7 7-7"></path>
        </svg>
      </button>
      <button
        id="nextBtn"
        class="absolute right-2 sm:right-4 top-1/2 -translate-y-1/2 bg-white/80 hover:bg-white text-gray-800 rounded-full p-2 sm:p-3 shadow-lg transition-all hover:scale-110"
        aria-label="Siguiente"
      >
        <svg
          class="w-4 h-4 sm:w-6 sm:h-6"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M9 5l7 7-7 7"></path>
        </svg>
      </button>

      <div class="flex justify-center mt-4 space-x-2">
        <button
          class="w-2 h-2 sm:w-3 sm:h-3 rounded-full bg-pink-400 transition-all"
          data-slide="0"></button>
        <button
          class="w-2 h-2 sm:w-3 sm:h-3 rounded-full bg-gray-300 transition-all"
          data-slide="1"></button>
        <button
          class="w-2 h-2 sm:w-3 sm:h-3 rounded-full bg-gray-300 transition-all"
          data-slide="2"></button>
      </div>
    </div>
  </div>
</section>
