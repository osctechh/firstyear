---
import CASTILLO from "../../public/CASTILLO.svg";
---

<section
  class="min-h-screen relative flex items-center justify-center overflow-hidden -mt-20"
>
  <img
    src={CASTILLO.src}
    alt=""
    class="absolute w-full h-full object-contain opacity-60 object-top max-w-4xl mx-auto"
  />

  <!-- Overlay pastel suave con transición superior -->
  <div
    class="absolute inset-0 bg-linear-to-b from-white/30 via-purple-100/50 to-pink-100/50 z-10"
  >
  </div>

  <!-- Contenido de texto -->
  <div class="relative z-20 text-center px-3 sm:px-4 md:px-6">
    <h2
      class="text-3xl sm:text-4xl md:text-5xl font-bold text-purple-800 mb-3 sm:mb-4 drop-shadow-lg"
    >
      Te invito a festejar mi 1er año
    </h2>
    <p
      class="text-base sm:text-lg md:text-xl text-purple-700 max-w-xs sm:max-w-md md:max-w-2xl mx-auto drop-shadow-md"
    >
      Segunda sección con diferentes colores y contenido. El scroll es suave
      gracias a la clase scroll-smooth.
    </p>
  </div>
</section>
