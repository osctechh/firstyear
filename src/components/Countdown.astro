---
const TIMESTAMP_END = 1777662000000;
---

<section class="flex flex-col gap-y-2 sm:gap-y-3 justify-center items-center">
  <div
    class="flex flex-row gap-x-2 sm:gap-x-3 md:gap-x-4 uppercase font-semibold"
    data-date={TIMESTAMP_END}
  >
    <div
      class="flex flex-col justify-center items-center bg-gradient-to-br from-pink-300 to-purple-400 rounded-xl p-2 sm:p-2.5 border-2 border-white shadow-lg gap-y-1 w-12 sm:w-14 md:w-16 transform hover:scale-105 transition-transform"
    >
      <span
        class="text-xl sm:text-2xl md:text-3xl font-bold text-white drop-shadow-md"
        data-days>00</span
      >
      <span class="text-xs sm:text-sm font-semibold text-white">Días</span>
    </div>

    <span
      aria-hidden="true"
      class="mt-1 text-lg sm:text-xl md:text-2xl text-white font-bold drop-shadow-md"
      >:</span
    >

    <div
      class="flex flex-col justify-center items-center bg-gradient-to-br from-purple-400 to-indigo-500 rounded-xl p-2 sm:p-2.5 border-2 border-white shadow-lg gap-y-1 w-12 sm:w-14 md:w-16 transform hover:scale-105 transition-transform"
    >
      <span
        class="text-xl sm:text-2xl md:text-3xl font-bold text-white drop-shadow-md"
        data-hours>00</span
      >
      <span class="text-xs sm:text-sm font-semibold text-white">Horas</span>
    </div>

    <span
      aria-hidden="true"
      class="mt-1 text-lg sm:text-xl md:text-2xl text-white font-bold drop-shadow-md"
      >:</span
    >

    <div
      class="flex flex-col justify-center items-center bg-gradient-to-br from-indigo-500 to-blue-500 rounded-xl p-2 sm:p-2.5 border-2 border-white shadow-lg gap-y-1 w-12 sm:w-14 md:w-16 transform hover:scale-105 transition-transform"
    >
      <span
        class="text-xl sm:text-2xl md:text-3xl font-bold text-white drop-shadow-md"
        data-minutes>00</span
      >
      <span class="text-xs sm:text-sm font-semibold text-white">Minutos</span>
    </div>

    <span
      aria-hidden="true"
      class="mt-1 text-lg sm:text-xl md:text-2xl text-white font-bold drop-shadow-md"
      >:</span
    >

    <div
      class="flex flex-col justify-center items-center bg-gradient-to-br from-blue-500 to-teal-500 rounded-xl p-2 sm:p-2.5 border-2 border-white shadow-lg gap-y-1 w-12 sm:w-14 md:w-16 transform hover:scale-105 transition-transform"
    >
      <span
        class="text-xl sm:text-2xl md:text-3xl font-bold text-white drop-shadow-md"
        data-seconds>00</span
      >
      <span class="text-xs sm:text-sm font-semibold text-white">Segundos</span>
    </div>
  </div>
</section>

<script>
  import type Countdown from "./Countdown.astro";

  const SECOND = 1000;
  const MINUTE = 60 * SECOND;
  const HOUR = 60 * MINUTE;
  const DAY = 24 * HOUR;

  function init() {
    const $countdown = document.querySelector("[data-date]");
    if (!$countdown) return;
    const $days = document.querySelector("[data-days]");
    const $hours = document.querySelector("[data-hours]");
    const $minutes = document.querySelector("[data-minutes]");
    const $seconds = document.querySelector("[data-seconds]");

    const timestamp = $countdown.getAttribute("data-date");
    if (!timestamp) return;

    const date = new Date(+timestamp).getTime();

    const formaTime = (time: number) => {
      return Math.floor(time).toString().padStart(2, "0");
    };

    function updateCountdown() {
      const now = Date.now();
      const diff = date - now;

      if ($days instanceof HTMLElement) {
        $days.innerText = formaTime(diff / DAY);
      }

      if ($hours instanceof HTMLElement) {
        $hours.innerText = formaTime((diff % DAY) / HOUR);
      }

      if ($minutes instanceof HTMLElement) {
        $minutes.innerText = formaTime((diff % HOUR) / MINUTE);
      }

      if ($seconds instanceof HTMLElement) {
        $seconds.innerText = formaTime((diff % MINUTE) / SECOND);
      }
    }
    setInterval(updateCountdown, SECOND);
  }
  init();
</script>
