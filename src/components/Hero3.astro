---
import mapCumple from "../assets/snazzy-image.webp";
import imgOri from "../../public/sinfondo.svg";
import Whatsapp from "../../public/whatsapp.svg";
---

<section
  class="min-h-screen relative flex items-center justify-center overflow-hidden"
>
  <!-- Audio de fondo con controles -->
  <audio id="musica-fondo" loop>
    <source src="/musica-fondo.mp3" type="audio/mpeg" />
    <source src="/musica-fondo.ogg" type="audio/ogg" />
    Tu navegador no soporta el elemento de audio.
  </audio>

  <!-- Controles de música -->
  <div
    class="fixed top-4 right-4 z-50 flex items-center gap-2 bg-white/90 backdrop-blur-sm rounded-full p-2 shadow-lg"
  >
    <button
      id="play-pause-btn"
      class="w-10 h-10 bg-pink-500 hover:bg-pink-600 text-white rounded-full flex items-center justify-center transition-all hover:scale-110"
      aria-label="Reproducir/Pausar música"
    >
      <svg
        id="play-icon"
        class="w-5 h-5 hidden"
        fill="currentColor"
        viewBox="0 0 24 24"
      >
        <path d="M8 5v14l11-7z"></path>
      </svg>
      <svg
        id="pause-icon"
        class="w-5 h-5"
        fill="currentColor"
        viewBox="0 0 24 24"
      >
        <path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"></path>
      </svg>
    </button>

    <div class="flex items-center gap-2">
      <svg
        class="w-4 h-4 text-gray-600"
        fill="currentColor"
        viewBox="0 0 24 24"
      >
        <path
          d="M3 9v6h4l5-5v10l-5-5h4V9H3zm13.5 3c0-1.77-1.02-3.29-2.5-4.03v8.05c1.48-.73 2.5-2.25 2.5-4.02V12c0-1.8-1.5-3.5-2.5-4.5z"
        ></path>
      </svg>
      <input
        type="range"
        id="volume-control"
        min="0"
        max="100"
        value="30"
        class="w-20 h-1 bg-gray-300 rounded-lg appearance-none cursor-pointer"
        aria-label="Control de volumen"
      />
    </div>
  </div>

  <img
    src={imgOri.src}
    alt=""
    class="absolute inset-0 w-full h-full object-cover z-0 opacity-60"
  />

  <!-- Overlay pastel suave -->
  <div
    class="absolute inset-0 bg-gradient-to-b from-purple-100/50 to-pink-100/50 z-10"
  >
  </div>

  <!-- Contenido de texto -->
  <div class="relative z-20 text-center px-3 sm:px-4 md:px-6">
    <h2
      class="text-3xl sm:text-4xl md:text-5xl font-bold text-purple-800 mb-3 sm:mb-4 drop-shadow-lg"
    >
      Confirmar asistencia.
    </h2>
    <a
      href="https://wa.me/542995693132"
      target="_blank"
      aria-label="Contactar por WhatsApp"
      class="inline-block mb-4 sm:mb-6"
    >
      <img
        src={Whatsapp.src}
        alt="WhatsApp"
        class="w-10 h-10 sm:w-12 sm:h-12"
      />
    </a>
    <p
      class="text-sm sm:text-base md:text-2xl lg:text-3xl font-semibold text-purple-700 max-w-xs sm:max-w-md md:max-w-2xl mx-auto drop-shadow-md px-4"
    >
      Los esperamos en salon El Castillo, ubicado en calle Viterbori N°289, a
      partir de las 18:00 hs a 21:00 hs.
    </p>

    <h3
      class="text-xl sm:text-2xl md:text-3xl font-bold text-purple-800 mt-8 sm:mt-10 text-center"
    >
      Ubicación
    </h3>
    <a
      href="https://www.google.com.ar/maps/place/El+Castillo/@-39.0467962,-67.5814399,17z/data=!3m1!4b1!4m6!3m5!1s0x960a1d492dcb6569:0x6cfc2fe60d77c24d!8m2!3d-39.0468004!4d-67.578865!16s%2Fg%2F11df2q08v9?entry=ttu&g_ep=EgoyMDI2MDMyNC4wIKXMDSoASAFQAw%3D%3D"
      class="block transition-all duration-300 ease-in-out hover:scale-105 active:scale-105 mx-2 sm:mx-0"
    >
      <img
        src={mapCumple.src}
        alt="Mapa de ubicación"
        class="w-full h-64 sm:h-80 md:h-96 rounded-2xl sm:rounded-3xl transition-all duration-300 ease-in-out hover:shadow-2xl active:shadow-2xl"
      />
    </a>
  </div>
</section>

<script>
  let isPlaying = false;
  const audio = document.getElementById("musica-fondo") as HTMLAudioElement;
  const playPauseBtn = document.getElementById("play-pause-btn");
  const playIcon = document.getElementById("play-icon");
  const pauseIcon = document.getElementById("pause-icon");
  const volumeControl = document.getElementById(
    "volume-control",
  ) as HTMLInputElement;

  // Configurar volumen inicial
  if (audio) {
    audio.volume = 0.3;
  }

  // Función play/pause
  function togglePlayPause() {
    if (!audio || !playIcon || !pauseIcon) return;

    if (isPlaying) {
      audio.pause();
      playIcon.classList.remove("hidden");
      pauseIcon.classList.add("hidden");
    } else {
      audio.play();
      playIcon.classList.add("hidden");
      pauseIcon.classList.remove("hidden");
    }
    isPlaying = !isPlaying;
  }

  // Función volumen
  function updateVolume() {
    if (audio && volumeControl) {
      audio.volume = volumeControl.valueAsNumber / 100;
    }
  }

  // Event listeners
  if (playPauseBtn) {
    playPauseBtn.addEventListener("click", togglePlayPause);
  }

  if (volumeControl) {
    volumeControl.addEventListener("input", updateVolume);
  }

  // Intentar autoplay (puede ser bloqueado)
  document.addEventListener(
    "click",
    function initAudio() {
      if (!isPlaying && audio) {
        audio
          .play()
          .then(() => {
            isPlaying = true;
            if (playIcon) playIcon.classList.add("hidden");
            if (pauseIcon) pauseIcon.classList.remove("hidden");
          })
          .catch(() => {
            // Autoplay bloqueado - esperar interacción del usuario
          });
      }
    },
    { once: true },
  );
</script>
