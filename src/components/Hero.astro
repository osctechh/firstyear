<section class="flex flex-col mt-10 justify-center items-center">
  <div>
    <span class="uppercase text-4xl px-2 py-1 font-bold rounded-xl"
      >Mi primer año</span
    >
    <h2 class="uppercase text-6xl">
      1 de Mayo
      <span aria-hidden class="hidden md:inline mx-1"></span>
      <br aria-hidden class="block md:hidden" />
      <span>
        <script is:inline>
          const END_DATE = 1777662000000;
          const d = new Date(END_DATE);
          const date = d.toLocaleDateString("es", {
            hour: "2-digit",
            minute: "2-digit",
          });

          const selfScript = document.currentScript;
          selfScript.parentNode.innerHTML = `${date}`;
        </script>
      </span>
    </h2>
  </div>
</section>
