---
import Hero from "../components/Hero.astro";
import Layout from "../layouts/Layout.astro";
import Main from "../components/Hero2.astro";
import Hero3 from "../components/Hero3.astro";
import Carrusel from "../components/Carrusel.astro";
---

<Layout>
  <picture class="relative block w-full min-h-screen">
    <div
      class="absolute mb-2 inset-0 flex flex-col items-center justify-between gap-y-4 sm:gap-y-8 md:gap-y-4 pt-4 sm:pt-8 md:pt-10 pb-8 sm:pb-20 md:pb-24 px-2 sm:px-4"
    >
      <Hero />
    </div>
    <div
      class="pointer-events-none absolute bottom-0 left-0 right-0 h-32 sm:h-36 md:h-40 lg:h-48 xl:h-56 bg-linear-to-b from-transparent to-[#FFE4EC]"
    >
    </div>
    <div
      class="fixed bottom-4 sm:bottom-6 right-0 left-0 mx-auto animate-bounce"
    >
      <svg
        class="w-8 h-8 sm:w-10 sm:h-10 md:w-12 md:h-12 mx-auto text-pink-600"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
      </svg>
    </div>
  </picture>
  <Carrusel />

  <Main />
  <Hero3 />
</Layout>
